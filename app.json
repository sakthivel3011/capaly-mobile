{
  "expo": {
    "name": "CAPALY",
    "slug": "capaly-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "capaly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "in.capaly.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CAPALY needs camera access to attach incident, investigation, CAPA and inspection photos.",
        "NSPhotoLibraryUsageDescription": "CAPALY needs photo library access to attach images to reports."
      }
    },
    "android": {
      "package": "in.capaly.beta",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "CAPALY needs photo library access to attach images to reports.",
          "cameraPermission": "CAPALY needs camera access to attach incident, investigation, CAPA and inspection photos.",
          "microphonePermission": false
        }
      ],
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "color": "#233DFF"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "./plugins/withReactNativeArchitectures",
        {
          "abis": "armeabi-v7a,arm64-v8a"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.capaly.in/api",
      "eas": {
        "projectId": "e07f61e5-085e-47e7-b392-9a913ed327a1"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e07f61e5-085e-47e7-b392-9a913ed327a1"
    }
  }
}
